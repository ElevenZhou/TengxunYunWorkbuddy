// AI搭子数据库Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  avatar    String?
  bio       String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflows   Workflow[]
  favorites   Favorite[]
  reviews     Review[]
  comments    Comment[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// 分类
model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  icon      String?
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tools     Tool[]
  workflows Workflow[]

  @@map("categories")
}

// 标签
model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())

  tools     Tool[]
  workflows Workflow[]

  @@map("tags")
}

// AI工具
model Tool {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  logo        String?
  website     String?
  pricing     String?  // free, freemium, paid
  status      ToolStatus @default(PENDING) // pending, approved, rejected
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  viewCount   Int      @default(0)
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  tags        Tag[]
  reviews     Review[]
  favorites   Favorite[]

  @@index([categoryId])
  @@index([status])
  @@map("tools")
}

enum ToolStatus {
  PENDING
  APPROVED
  REJECTED
}

// 工作流
model Workflow {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  description String        @db.Text
  cover       String?
  steps       Json          // 步骤JSON数组
  status      WorkflowStatus @default(DRAFT) // draft, published
  useCount    Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  authorId    String
  author      User          @relation(fields: [authorId], references: [id])

  categoryId  String?
  category    Category?    @relation(fields: [categoryId], references: [id])

  tags        Tag[]
  reviews     Review[]

  @@index([authorId])
  @@index([status])
  @@map("workflows")
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// 评价
model Review {
  id        String   @id @default(uuid())
  content   String   @db.Text
  rating    Int      // 1-5
  helpful   Int      @default(0)
  status    ReviewStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  toolId    String?
  tool      Tool?    @relation(fields: [toolId], references: [id])

  workflowId String?
  workflow  Workflow? @relation(fields: [workflowId], references: [id])

  @@index([toolId])
  @@index([workflowId])
  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// 收藏
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  toolId    String?
  workflowId String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  tool      Tool?    @relation(fields: [toolId], references: [id])
  workflow  Workflow? @relation(fields: [workflowId], references: [id])

  @@unique([userId, toolId])
  @@unique([userId, workflowId])
  @@map("favorites")
}

// 热度记录
model TrendRecord {
  id        String   @id @default(uuid())
  toolId    String
  date      DateTime @db.Date
  trendScore Float   @default(0)
  googleTrends Float @default(0)
  socialScore Float  @default(0)
  newsScore  Float   @default(0)
  searchScore Float  @default(0)
  createdAt DateTime @default(now())

  @@unique([toolId, date])
  @@index([date])
  @@map("trend_records")
}
